{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "storybook: dev",
      "type": "npm",
      "script": "storybook",
      "isBackground": true,
      "problemMatcher": {
        "pattern": {
          "regexp": "."
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "storybook dev",
          "endsPattern": "Storybook .* started"
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      }
    }
  ]
}
